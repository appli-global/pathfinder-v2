# Copy this file to .env.local and fill in your real keys.
# This file is intentionally NOT committed with secrets. The repo's .gitignore
# ignores files ending with `.local` so .env.local will not be committed.

# Gemini API key for @google/genai. Use VITE_ prefix to expose to Vite client builds.
# For local dev (recommended): set VITE_GEMINI_API_KEY. The service will also accept
# GEMINI_API_KEY (server-side) for non-Vite contexts.

# Example (replace with your real key):
VITE_GEMINI_API_KEY=your_real_gemini_api_key_here

# Optional: If you prefer process.env lookups in Node, you can also set:
# GEMINI_API_KEY=your_real_gemini_api_key_here

# Usage:
# 1. Copy to a new file:
#    cp .env.local.example .env.local
# 2. Edit `.env.local` and paste your actual key.
# 3. Start dev server:
#    npm run dev
